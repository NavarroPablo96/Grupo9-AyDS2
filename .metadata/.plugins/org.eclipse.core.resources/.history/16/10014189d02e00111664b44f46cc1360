package gestorInterfazOperador;

public class Turno {
	private String Documento,HoraReg;
	private int Numero;

	public Turno(int numero, String documento, String horaReg) {
		Numero = numero;
		Documento = documento;
		HoraReg = horaReg;
	}

	public int getNumero() {
		return Numero;
	}

	public String getDocumento() {
		return Documento;
	}

	public String getHoraRegistro() {
		return HoraReg;
	}

}
