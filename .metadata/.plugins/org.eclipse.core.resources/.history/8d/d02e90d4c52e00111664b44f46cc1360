package gestorInterfazOperador;

public class Turno {
	private String Numero,Documento,HoraReg;

	public Turno(String numero, String documento, String horaReg) {
		Numero = numero;
		Documento = documento;
		HoraReg = horaReg;
	}

	public String getNumero() {
		return Numero;
	}

	public String getDocumento() {
		return Documento;
	}

	public String getHoraRegistro() {
		return HoraReg;
	}

}
