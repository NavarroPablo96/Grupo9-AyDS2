package vista_controlador;

import java.awt.EventQueue;

import javax.swing.JFrame;
import javax.swing.JPanel;

import java.awt.*;
import javax.swing.*;

public class ConexionFrame extends JFrame {

    private JTextField txtReceptorIP, txtReceptorPuerto;
    private JButton btnEscuchar;

    private JTextField txtEmisorIP, txtEmisorPuerto;
    private JButton btnConectar;

    public ConexionFrame() {
        setTitle("Conexión - Operador");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setBounds(100, 100, 400, 250);

        JPanel contentPane = new JPanel();
        contentPane.setLayout(new BoxLayout(contentPane, BoxLayout.Y_AXIS));
        contentPane.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));
        setContentPane(contentPane);

        // -------------------
        // PANEL RECEPTOR
        // -------------------
        JPanel panelReceptor = new JPanel();
        panelReceptor.setBorder(BorderFactory.createTitledBorder("Escuchar"));
        panelReceptor.setLayout(new GridBagLayout());
        GridBagConstraints gbcReceptor = new GridBagConstraints();
        gbcReceptor.insets = new Insets(5, 5, 5, 5);

        gbcReceptor.gridx = 0;
        gbcReceptor.gridy = 0;
        panelReceptor.add(new JLabel("IP:"), gbcReceptor);

        gbcReceptor.gridx = 1;
        txtReceptorIP = new JTextField(15);
        txtReceptorIP.setText("127.0.0.1"); // IP local por defecto
        panelReceptor.add(txtReceptorIP, gbcReceptor);

        gbcReceptor.gridx = 0;
        gbcReceptor.gridy = 1;
        panelReceptor.add(new JLabel("Puerto:"), gbcReceptor);

        gbcReceptor.gridx = 1;
        txtReceptorPuerto = new JTextField(15);
        txtReceptorPuerto.setText("1234");
        panelReceptor.add(txtReceptorPuerto, gbcReceptor);

        gbcReceptor.gridx = 0;
        gbcReceptor.gridy = 2;
        gbcReceptor.gridwidth = 2;
        btnEscuchar = new JButton("Escuchar");
        panelReceptor.add(btnEscuchar, gbcReceptor);

        contentPane.add(panelReceptor);
        contentPane.add(Box.createVerticalStrut(20));

        // -------------------
        // PANEL EMISOR
        // -------------------
        JPanel panelEmisor = new JPanel();
        panelEmisor.setBorder(BorderFactory.createTitledBorder("Conectar"));
        panelEmisor.setLayout(new GridBagLayout());
        GridBagConstraints gbcEmisor = new GridBagConstraints();

        gbcEmisor = new GridBagConstraints();
        gbcEmisor.insets = new Insets(5, 5, 5, 5);

        gbcEmisor.gridx = 0;
        gbcEmisor.gridy = 0;
        panelEmisor.add(new JLabel("IP:"), gbcEmisor);

        gbcEmisor.gridx = 1;
        txtEmisorIP = new JTextField(15);
        txtEmisorIP.setText("127.0.0.1"); // IP destino
        panelEmisor.add(txtEmisorIP, gbcEmisor);

        gbcEmisor.gridx = 0;
        gbcEmisor.gridy = 1;
        panelEmisor.add(new JLabel("Puerto:"), gbcEmisor);

        gbcEmisor.gridx = 1;
        txtEmisorPuerto = new JTextField(15);
        txtEmisorPuerto.setText("1235"); // Puerto destino
        panelEmisor.add(txtEmisorPuerto, gbcEmisor);

        gbcEmisor.gridx = 0;
        gbcEmisor.gridy = 2;
        gbcEmisor.gridwidth = 2;
        btnConectar = new JButton("Conectar");
        panelEmisor.add(btnConectar, gbcEmisor);

        contentPane.add(panelEmisor);
    }

    public static void main(String[] args) {
        EventQueue.invokeLater(() -> {
            ConexionFrame frame = new ConexionFrame();
            frame.setVisible(true);
        });
    }
}