package vista_controlador;

import java.awt.*;
import javax.swing.*;
import javax.swing.border.EmptyBorder;
import javax.swing.table.DefaultTableModel;

public class VistaOperador extends JFrame {

    private JPanel contentPane;

    public VistaOperador() {
        setTitle("Panel de Operador");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setBounds(100, 100, 600, 600);

        contentPane = new JPanel();
        contentPane.setLayout(new BorderLayout(10, 10));
        contentPane.setBorder(new EmptyBorder(10, 10, 10, 10));
        setContentPane(contentPane);

        // 🔵 PANEL PRINCIPAL (vertical)
        JPanel panelCentral = new JPanel();
        panelCentral.setLayout(new BoxLayout(panelCentral, BoxLayout.Y_AXIS));
        contentPane.add(panelCentral, BorderLayout.CENTER);

        // 🟢 BOTÓN GRANDE
        JButton btnLlamar = new JButton("Llamar siguiente");
        btnLlamar.setFont(new Font("Arial", Font.BOLD, 20));
        btnLlamar.setPreferredSize(new Dimension(200, 60));
        btnLlamar.setMaximumSize(new Dimension(Integer.MAX_VALUE, 60));
        panelCentral.add(btnLlamar);

        panelCentral.add(Box.createVerticalStrut(10));

        // 🟡 PANEL DE CUADRADOS (2 columnas)
        JPanel panelStats = new JPanel(new GridLayout(1, 2, 10, 10));

        panelStats.add(crearCuadrado("6", "En espera"));
        panelStats.add(crearCuadrado("7", "Total atendidos hoy"));

        panelCentral.add(panelStats);

        panelCentral.add(Box.createVerticalStrut(10));

        // 🔴 ÚLTIMO CLIENTE
        JPanel panelUltimo = new JPanel();
        panelUltimo.setLayout(new BoxLayout(panelUltimo, BoxLayout.Y_AXIS));
        panelUltimo.setBorder(BorderFactory.createLineBorder(Color.GRAY));

        JLabel lblTitulo = new JLabel("Último cliente llamado (Turno #006)");
        lblTitulo.setAlignmentX(Component.CENTER_ALIGNMENT);

        JLabel lblDni = new JLabel("38291047");
        lblDni.setFont(new Font("Arial", Font.BOLD, 24));
        lblDni.setAlignmentX(Component.CENTER_ALIGNMENT);

        panelUltimo.add(lblTitulo);
        panelUltimo.add(lblDni);

        panelCentral.add(panelUltimo);

        panelCentral.add(Box.createVerticalStrut(10));

        // 🟣 TABLA
        String[] columnas = {"#", "Documento", "Hora Reg.", "Estado"};

        Object[][] datos = {
                {"007", "38291047", "10:42", "Próximo"},
                {"008", "20110334", "10:44", "Espera"},
                {"009", "30111222", "10:45", "Espera"},
                {"010", "40122333", "10:47", "Espera"}
        };

        JTable tabla = new JTable(new DefaultTableModel(datos, columnas));
        JScrollPane scroll = new JScrollPane(tabla);

        panelCentral.add(scroll);
    }

    // 🧩 Método para crear los cuadraditos
    private JPanel crearCuadrado(String numero, String texto) {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));
        panel.setBorder(BorderFactory.createLineBorder(Color.GRAY));

        JLabel lblNumero = new JLabel(numero);
        lblNumero.setFont(new Font("Arial", Font.BOLD, 20));
        lblNumero.setAlignmentX(Component.CENTER_ALIGNMENT);

        JLabel lblTexto = new JLabel(texto);
        lblTexto.setAlignmentX(Component.CENTER_ALIGNMENT);

        panel.add(lblNumero);
        panel.add(lblTexto);

        return panel;
    }

    public static void main(String[] args) {
        EventQueue.invokeLater(() -> {
            try {
                VistaOperador frame = new VistaOperador();
                frame.setVisible(true);
            } catch (Exception e) {
                e.printStackTrace();
            }
        });
    }
}
